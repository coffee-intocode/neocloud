# Application configuration
APP_NAME=Neocloud API
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true

# API configuration
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Supabase auth and database
SUPABASE_URL=
SUPABASE_DATABASE_URL=postgresql+asyncpg://postgres:password@your-project.supabase.co:5432/postgres
ALEMBIC_DB_URL=postgresql://postgres:password@your-project.supabase.co:5432/postgres

# Brokkr API
BROKKR_API_KEY=
BROKKR_BASE_URL=https://brokkr.hydrahost.com/api/v1
BROKKR_TIMEOUT_SECONDS=15

# AI provider API keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
